# Пример inventory (актуальные IP задаёт Terraform: make apply)
[webservers]
server1 ansible_host=192.168.100.11 ansible_user=student
server2 ansible_host=192.168.100.12 ansible_user=student

[balancer]
balancer01 ansible_host=192.168.100.10 ansible_user=student

[postgres]
postgres01 ansible_host=192.168.100.13 ansible_user=student

[all:vars]
ansible_python_interpreter=/usr/bin/python3
