{{ wiki_domain }} {
    tls internal
    reverse_proxy {
        {% for host in groups['webservers'] %}
        to {{ hostvars[host]['ansible_host'] }}:{{ wiki_port }}
        {% endfor %}
        lb_policy round_robin
        health_uri /
        health_interval 10s
        health_timeout 5s
    }
}

:{{ http_port }} {
    redir https://{{ wiki_domain }}{uri} permanent
}
